# ─── Telegram Bot ────────────────────────────────────────────────────────────────────
# Ottieni il token da @BotFather su Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Il tuo Telegram chat ID (o quello del gruppo)
TELEGRAM_CHAT_ID=987654321

# Chat ID autorizzato per comandi critici (/pause, /resume).
# Default: uguale a TELEGRAM_CHAT_ID se non specificato.
TELEGRAM_ALLOWED_CHAT_ID=987654321

# ─── Alternative senza underscore (supportate come fallback) ─────────────────
# TELEGRAMBOTTOKEN=
# TELEGRAMCHATID=
